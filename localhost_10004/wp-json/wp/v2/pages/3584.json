: 100px;\n}\n\n.faq .e-n-accordion-item{\n    box-shadow: 4px 4px 0px #000000;\nborder-radius: 20px;\n}\n\n\n.faq .e-n-accordion-item[open] .e-n-accordion-item-title{\n    \/*padding-bottom: 16px;*\/\n    border-radius: 20px 20px 0  0;\n}\n\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-341a1c3 e-con e-atomic-element e-flexbox-base e-ebf4eb2 \" data-id=\"341a1c3\" data-element_type=\"e-flexbox\" data-e-type=\"e-flexbox\" data-interaction-id=\"341a1c3\">\n    \t\t<div class=\"elementor-element elementor-element-34c04cc elementor-widget elementor-widget-html\" data-id=\"34c04cc\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<style>\n     .marquee-img {\n  overflow: hidden;\n}\n\n.marquee-img > div {\n    gap: var(--gap);\n}\n\n.marquee-img .elementor-widget-image {\n  flex-shrink: 0;\n  will-change: transform;\n}\n\n.marquee-img .elementor-widget-image img {\n  display: block;\n}\n\n\n.marquee-text-container {\n  overflow: hidden;\n  width: 100%;\n}\n\n.marquee-wrapper {\n  display: flex;\n  width: max-content;\n}\n\n.marquee-text-container .elementor-widget-heading {\n  flex-shrink: 0;\n  white-space: nowrap;\n  padding-right: 2px; \/* spacing instead of gap *\/\n}\n<\/style>\n<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/gsap\/3.13.0\/gsap.min.js\"><\/script>\n<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/gsap\/3.13.0\/ScrollTrigger.min.js\"><\/script>\n<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/gsap\/3.13.0\/CustomEase.min.js\"><\/script>\n\n\n<script>\nwindow.addEventListener(\"load\", () => {\n  if (!window.gsap) return;\n  gsap.registerPlugin(ScrollTrigger);\n\n  const marquees = [];\n  const CLONE_COUNT = 6; \/\/ \ud83d\udc48 increase \/ decrease here\n\n  function setupMarquee(container, items) {\n    const wrapper = document.createElement(\"div\");\n    wrapper.className = \"marquee-wrapper\";\n\n    \/\/ original\n    items.forEach(item => wrapper.appendChild(item));\n\n    \/\/ clone MANY times\n    for (let i = 0; i < CLONE_COUNT; i++) {\n      items.forEach(item => {\n        wrapper.appendChild(item.cloneNode(true));\n      });\n    }\n\n    container.appendChild(wrapper);\n\n    const width = items.reduce((acc, el) => {\n      const style = getComputedStyle(el);\n      return acc + el.offsetWidth + parseFloat(style.marginRight || 0);\n    }, 0);\n\n    marquees.push({\n      wrapper,\n      loopWidth: width * (CLONE_COUNT + 1),\n      singleWidth: width,\n      x: 0,\n      speed: -0.6,\n      baseSpeed: 0.6\n    });\n  }\n\n  \/* TEXT *\/\n  document.querySelectorAll(\".marquee-text-container\").forEach(container => {\n    const item = container.querySelector(\".elementor-widget-heading\");\n    if (!item) return;\n    setupMarquee(container, [item]);\n  });\n\n  \/* IMAGE *\/\n  document.querySelectorAll(\".marquee-img\").forEach(container => {\n    const items = Array.from(\n      container.querySelectorAll(\".elementor-widget-image\")\n    );\n    if (!items.length) return;\n    setupMarquee(container, items);\n  });\n\n  \/* SINGLE TICKER *\/\n  gsap.ticker.add(() => {\n    marquees.forEach(m => {\n      m.x += m.speed;\n\n      \/\/ BIG LOOP RESET (far away)\n      if (m.x <= -m.loopWidth) m.x += m.loopWidth;\n      if (m.x >= 0) m.x -= m.loopWidth;\n\n      gsap.set(m.wrapper, { x: m.x });\n    });\n  });\n\n  \/* SCROLL DIRECTION *\/\n  ScrollTrigger.create({\n    start: 0,\n    end: \"max\",\n    onUpdate(self) {\n      const boost = Math.min(Math.abs(self.getVelocity()) \/ 1200, 2);\n      marquees.forEach(m => {\n        m.speed =\n          self.direction === -1\n            ? m.baseSpeed + boost\n            : -(m.baseSpeed + boost);\n      });\n    }\n  });\n});\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\n<\/div>\n\t\t<\/div>\n\t\t","protected":false}